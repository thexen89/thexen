generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String   @id @default(cuid())
  name           String
  client         String
  images         String[]
  thumbnailIndex Int      @default(0)
  description    String
  priority       Int
  shape          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
