generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String   @id @default(cuid())
  name           String
  client         String
  images         String[]
  thumbnailIndex Int      @default(0)
  description    String
  priority       Int
  shape          String?
  showInfo       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default("default")
  seasonalEffect  String?  // 'snow' | 'cherry' | 'leaves' | 'fireworks' | null
  effectEnabled   Boolean  @default(false)
  // 회사 소개 정보
  companyImages   String[] // 회사 소개 이미지들
  companyDescription String? // 회사 소개 텍스트
  // 랜딩페이지 커스터마이징
  landingLogoImage String?  // 로고 이미지 URL (SVG 권장)
  landingBackgroundImage String?  // 배경 이미지 URL
  landingBackgroundType String?  // 'tile' | 'cover' - 타일링 또는 전체 커버
  landingEnterImage String?  // 엔터 버튼 이미지 URL
  updatedAt       DateTime @updatedAt
}
